{
  // Fail CI on ANY advisory of low severity or higher that is not explicitly
  // allowlisted below. Fail-closed: a new advisory at any severity breaks the
  // build until it is triaged (fixed, or consciously allowlisted with a reason).
  "low": true,
  "allowlist": [
    // @ai-sdk chain — 1 low. GHSA-866g-f22w-33x8: Uncontrolled Resource Consumption
    // in @ai-sdk/provider-utils (also surfaces on @ai-sdk/gateway, ai). No fix without
    // the ai@6 major SDK migration. REVISIT when the ai@6 migration slice is scoped.
    "GHSA-866g-f22w-33x8",
    // dompurify — via monaco-editor. Monaco VENDORS its own DOMPurify
    // (esm/vs/base/browser/dompurify/dompurify.js) and imports THAT, not the npm
    // package, so every advisory on the npm dompurify is a phantom for us. The npm
    // DB mints these often (8 → 12 in one afternoon) and audit-ci does NOT honor a
    // path-based allowlist, so each must be listed by GHSA id. REVISIT if anything
    // imports npm dompurify directly, or when monaco-editor bumps its vendored copy.
    "GHSA-39q2-94rc-95cp",
    "GHSA-76mc-f452-cxcm",
    "GHSA-cj63-jhhr-wcxv",
    "GHSA-cjmm-f4jc-qw8r",
    "GHSA-crv5-9vww-q3g8",
    "GHSA-h7mw-gpvr-xq4m",
    "GHSA-h8r8-wccr-v5f2",
    "GHSA-hpcv-96wg-7vj8",
    "GHSA-r47g-fvhr-h676",
    "GHSA-v2wj-7wpq-c8vv",
    "GHSA-v9jr-rg53-9pgp",
    "GHSA-x4vx-rjvf-j5p4",
    // postcss — 1 moderate. GHSA-qx2v-qp2m-jg93: XSS via unescaped </style>, transitive
    // through Next.js (also surfaces on next, @clerk/nextjs, @sentry/nextjs). No fix
    // published. REVISIT on the next Next.js upgrade.
    "GHSA-qx2v-qp2m-jg93",
    // js-yaml — GHSA-h67p-54hq-rp68: quadratic-complexity DoS in merge-key handling via
    // repeated aliases, transitive through gray-matter (blog front-matter parsing).
    // js-yaml only ever parses our OWN authored markdown front-matter at BUILD time,
    // never untrusted or runtime input, so the DoS vector isn't reachable. The only fix
    // is gray-matter@2 (breaking). REVISIT on a gray-matter@2 migration.
    "GHSA-h67p-54hq-rp68"
  ]
}
