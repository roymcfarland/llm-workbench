import { writeFile } from "node:fs/promises";
import path from "node:path";
import { fileURLToPath, pathToFileURL } from "node:url";

import Ajv from "ajv";
import standaloneCode from "ajv/dist/standalone/index.js";
import {
  demoArtifactTypes,
  demoRuleSchemas,
} from "@llm-workbench/runtime/host/demoSchemas";

import {
  scenarioArtifactTypes,
  scenarioRuleSchemas,
} from "../apps/web/lib/landing/scenarios/schemas.ts";

type SchemaDefinition = {
  id: string;
  schema: Record<string, unknown>;
};

const here = path.dirname(fileURLToPath(import.meta.url));
const repoRoot = path.resolve(here, "..");

export const GENERATED_VALIDATORS_PATH = path.join(
  repoRoot,
  "apps/web/lib/security/precompiled-validators.generated.mjs",
);

const GENERATED_HEADER = [
  "// Copyright 2026 Roy McFarland",
  "// SPDX-License-Identifier: LicenseRef-Proprietary",
  "// Generated by scripts/gen-validators.mts. Do not edit by hand.",
  "",
].join("\n");

function collectSchemaDefinitions(): SchemaDefinition[] {
  return [
    ...demoArtifactTypes,
    ...demoRuleSchemas,
    ...scenarioArtifactTypes,
    ...scenarioRuleSchemas,
  ];
}

function makeIdentifier(input: string): string {
  const normalized = input.replace(/[^A-Za-z0-9_$]/g, "_");
  return /^[A-Za-z_$]/.test(normalized) ? normalized : `_${normalized}`;
}

function uniqueIdentifier(input: string, used: Set<string>): string {
  const base = makeIdentifier(input);
  let candidate = base;
  let suffix = 2;
  while (used.has(candidate)) {
    candidate = `${base}_${suffix}`;
    suffix += 1;
  }
  used.add(candidate);
  return candidate;
}

function makeLookupEntry(id: string, exportName: string): string {
  return `  ${JSON.stringify(id)}: ${exportName},`;
}

function assertUniqueIds(definitions: SchemaDefinition[]): void {
  const seen = new Set<string>();
  const duplicates = definitions.flatMap(({ id }) => {
    if (!seen.has(id)) {
      seen.add(id);
      return [];
    }
    return [id];
  });

  if (duplicates.length > 0) {
    throw new Error(`Duplicate schema ids: ${duplicates.join(", ")}`);
  }
}

export function buildPrecompiledValidatorsModule(): string {
  const definitions = collectSchemaDefinitions();
  assertUniqueIds(definitions);

  const ajv = new Ajv({
    allErrors: true,
    strict: true,
    allowUnionTypes: true,
    code: { source: true, esm: true },
  });
  const usedSchemaKeys = new Set<string>();
  const usedExportNames = new Set<string>();
  const exportsMap: Record<string, string> = {};
  const lookupEntries: string[] = [];

  for (const { id, schema } of definitions) {
    const schemaKey = uniqueIdentifier(id, usedSchemaKeys);
    const exportName = uniqueIdentifier(`validate_${id}`, usedExportNames);
    ajv.addSchema(schema, schemaKey);
    exportsMap[exportName] = schemaKey;
    lookupEntries.push(makeLookupEntry(id, exportName));
  }

  return [
    GENERATED_HEADER,
    standaloneCode(ajv, exportsMap),
    "",
    "export const precompiledValidators = Object.freeze({",
    ...lookupEntries,
    "});",
    "",
  ].join("\n");
}

export async function writePrecompiledValidators(): Promise<void> {
  await writeFile(GENERATED_VALIDATORS_PATH, buildPrecompiledValidatorsModule(), "utf8");
}

if (process.argv[1] && import.meta.url === pathToFileURL(process.argv[1]).href) {
  await writePrecompiledValidators();
  console.log(`wrote ${path.relative(repoRoot, GENERATED_VALIDATORS_PATH)}`);
}
