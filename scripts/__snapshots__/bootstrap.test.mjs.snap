            "target": [
              "production",
              "preview",
              "development"
            ]
          },
          {
            "key": "NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL",
            "literal": "/playground",
            "target": [
              "production",
              "preview",
              "development"
            ]
          },
          {
            "key": "NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL",
            "literal": "/playground",
            "target": [
              "production",
              "preview",
              "development"
            ]
          },
          {
            "key": "NEXT_PUBLIC_SITE_ORIGIN",
            "from": "vercel.production_url",
