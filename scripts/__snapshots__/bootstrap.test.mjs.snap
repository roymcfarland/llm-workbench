      "skip": false,
      "skipReason": null,
      "suggestedTool": "plugin-clerk-clerk.create_application"
    },
    {
      "id": "clerk.fetch_api_keys",
      "provider": "clerk",
      "action": "fetch_api_keys",
      "description": "Read the publishable key and secret key for the application.",
