{
  "name": "@llm-workbench/ai-sdk",
  "version": "0.2.0",
  "description": "Vercel AI SDK wrappers that emit correlated model-I/O, tool-call, and cost trace events into an LLM Workbench run.",
  "keywords": [
    "llm",
    "ai",
    "vercel-ai-sdk",
    "tracing",
    "observability",
    "cost"
  ],
  "author": "Roy McFarland (https://github.com/roymcfarland)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roymcfarland/llm-workbench.git",
    "directory": "packages/ai-sdk"
  },
  "homepage": "https://www.llmworkbench.io",
  "bugs": "https://github.com/roymcfarland/llm-workbench/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@llm-workbench/runtime": "0.2.0"
  },
  "peerDependencies": {
    "ai": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "ai": "^5.0.179",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "zod": "^3.23.8"
  }
}
