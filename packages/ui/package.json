{
  "name": "@llm-workbench/ui",
  "version": "0.3.3",
  "description": "React control-surface components (WorkbenchShell) for inspecting and editing LLM Workbench runs — artifacts, rules, traces, gates, and bundle import/export.",
  "keywords": [
    "llm",
    "ai",
    "react",
    "ui",
    "observability",
    "workbench",
    "human-in-the-loop"
  ],
  "author": "Roy McFarland (https://github.com/roymcfarland)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roymcfarland/llm-workbench.git",
    "directory": "packages/ui"
  },
  "homepage": "https://www.llmworkbench.io",
  "bugs": "https://github.com/roymcfarland/llm-workbench/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "./dist/theme.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-theme.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@llm-workbench/adapters-react": "0.3.3",
    "@llm-workbench/runtime": "0.3.2",
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.11.2",
    "dagre": "^0.8.5",
    "react-virtuoso": "^4.18.10"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vitest": "^4.1.5"
  }
}
