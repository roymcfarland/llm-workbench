  "description": "Model Context Protocol (MCP) server factory and HTTP handler that exposes an LLM Workbench runtime over MCP.",
  "keywords": [
    "llm",
    "ai",
    "mcp",
    "model-context-protocol",
    "observability",
    "workbench"
  ],
  "author": "Roy McFarland (https://github.com/roymcfarland)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roymcfarland/llm-workbench.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://www.llmworkbench.io",
  "bugs": "https://github.com/roymcfarland/llm-workbench/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
