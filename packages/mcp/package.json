  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "zod": "^3.23.8"
  }
