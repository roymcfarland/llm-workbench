{
  "name": "@llm-workbench/runtime",
  "version": "0.3.2",
  "description": "Headless, model-agnostic runtime for LLM workflows — records state, artifacts, rules, human-review gates, traces, cost telemetry, and tamper-evident run bundles.",
  "keywords": [
    "llm",
    "ai",
    "agents",
    "observability",
    "workflow",
    "tracing",
    "human-in-the-loop",
    "run-bundle"
  ],
  "author": "Roy McFarland (https://github.com/roymcfarland)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roymcfarland/llm-workbench.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://www.llmworkbench.io",
  "bugs": "https://github.com/roymcfarland/llm-workbench/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./host/demoSchemas": {
      "types": "./dist/host/demoSchemas.d.ts",
      "import": "./dist/host/demoSchemas.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "import": "./dist/persistence/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "fast-json-patch": "^3.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
