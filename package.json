{
  "name": "llm-workbench",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "apps/*"
  ],
  "scripts": {
    "bootstrap": "node scripts/bootstrap.mjs",
    "blog:autopublish": "node scripts/blog-autopublish.mjs",
    "build": "npm run build -w @llm-workbench/runtime -w @llm-workbench/adapters-react -w @llm-workbench/ui -w @llm-workbench/ai-sdk -w @llm-workbench/mcp",
    "gen:validators": "npm run build -w @llm-workbench/runtime && tsx scripts/gen-validators.mts",
    "test": "npm test -w @llm-workbench/runtime && npm test -w @llm-workbench/adapters-react && npm test -w @llm-workbench/ai-sdk && npm test -w @llm-workbench/ui && npm test -w @llm-workbench/mcp && npm run test:scripts && npm test -w @llm-workbench/web",
    "test:scripts": "vitest run --config scripts/vitest.config.mjs",
    "demo": "npm run dev -w job-search-demo",
    "demo:http-server": "npm run start -w run-repo-server",
    "dev:web": "npm run dev -w apps/web",
    "build:web": "npm run build -w apps/web",
    "lint:packages": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "audit:check": "audit-ci --config audit-ci.jsonc",
    "smoke:esm": "node scripts/esm-smoke.mjs",
    "ci": "npm run build && npm run smoke:esm && npm test && npm run typecheck -w @llm-workbench/web && npm run lint -w @llm-workbench/web && npm run lint:packages && npm run build:web",
    "changeset": "changeset",
    "changeset:version": "changeset version && npm install --package-lock-only",
    "release": "npm run build && node scripts/release-publish.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "audit-ci": "^7.1.0",
    "eslint": "^9.39.4",
    "rss-parser": "^3.13.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "vite": {
      "esbuild": "0.28.1"
    }
  }
}
