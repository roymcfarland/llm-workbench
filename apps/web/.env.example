# ----------------------------------------------------------------------------
# LLM Workbench reference deployment — environment variables
#
# Copy to `.env.local` and fill in. Never commit real values.
# ----------------------------------------------------------------------------

# --- Supabase --------------------------------------------------------------
# Create a project at https://supabase.com, then copy the URL and the
# `service_role` key from Project Settings → API. We use the service role on
# the server only and gate access at the API layer (see SECURITY notes in
# `lib/supabase/runs-store.ts`).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Clerk -----------------------------------------------------------------
# Create an application at https://clerk.com. The publishable key is exposed
# to the browser; the secret key must stay server-side.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional Clerk redirect overrides (kept simple for the reference app).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/playground
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/playground

# --- Site origin -----------------------------------------------------------
# Canonical absolute origin. Used to build absolute URLs in
# `metadataBase`, sitemap.xml, robots.txt, /llms.txt, and the OpenAPI
# `servers` block. On Vercel, this is normally your production domain
# (e.g. https://workbench.llmworkbench.io). For local dev:
#   NEXT_PUBLIC_SITE_ORIGIN=http://localhost:3000
NEXT_PUBLIC_SITE_ORIGIN=https://workbench.example.com

# --- Vercel AI Gateway -----------------------------------------------------
# When deployed on Vercel, OIDC auth is preferred. For local development set
# AI_GATEWAY_API_KEY (https://vercel.com/docs/ai-gateway).
AI_GATEWAY_API_KEY=vck_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Site origin -----------------------------------------------------------
# Public canonical origin used by /sitemap.xml, /llms.txt, and OpenGraph
# metadata when the request `Host` header is unavailable (build-time, static
# generation). Leave unset locally; set on Vercel to your production domain
# (e.g. https://workbench.example.com).
NEXT_PUBLIC_SITE_ORIGIN=https://workbench.example.com
